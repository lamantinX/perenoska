# Perenoska — test environment variables
# Used by docker-compose for CI/test runs.
# Values are safe for testing — no real secrets.

APP_SECRET_KEY=test-secret-key-not-for-production-use-only
APP_DATABASE_PATH=/app/data/test.db
APP_SESSION_TTL_HOURS=1
PERENOSKA_PORT=8000

OPENROUTER_API_KEY=test-openrouter-key
LLM_MODEL=mistralai/mistral-7b-instruct:free
LLM_BASE_URL=https://openrouter.ai/api/v1
