# Perenoska — environment variables
# Copy this file to .env and fill in values.
# Dev defaults are provided where safe.

# ── Application ───────────────────────────────────────────────────────────────

# Fernet encryption key for API credentials stored in DB.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANT: keep secret, never commit the real value.
APP_SECRET_KEY=

# Path to SQLite database file inside the container.
APP_DATABASE_PATH=/app/data/perenositsa.db

# Session time-to-live in hours.
APP_SESSION_TTL_HOURS=24

# Port exposed on the host machine.
PERENOSKA_PORT=8000

# ── LLM (OpenRouter) ──────────────────────────────────────────────────────────

# API key for OpenRouter (https://openrouter.ai).
# Required for category mapping via LLM.
OPENROUTER_API_KEY=

# Model to use for category mapping. Free tier available.
LLM_MODEL=mistralai/mistral-7b-instruct:free

# OpenRouter-compatible base URL (OpenAI SDK compatible).
LLM_BASE_URL=https://openrouter.ai/api/v1
